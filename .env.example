# Multi-View RAG Configuration
# Copy this file to .env and fill in the values

# ===========================================
# Neo4j Configuration
# ===========================================
NEO4J_URI=bolt://localhost:7689
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# ===========================================
# OpenAI API (REQUIRED for LLM generation and embeddings)
# ===========================================
OPENAI_API_KEY=sk-your-key-here

# ===========================================
# Application Settings
# ===========================================
# Environment: development, staging, production
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ===========================================
# Frontend Settings
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ===========================================
# NOTES
# ===========================================
# - This system uses OpenAI for all LLM inference (NOT Claude/Anthropic)
# - Neo4j database should be running on the specified URI
# - For production, use secure passwords and HTTPS
